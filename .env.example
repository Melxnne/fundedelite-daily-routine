# Yahoo-Finance-Symbole (keine Secrets nötig, kein Login)
MARKET_SYMBOL_GOLD=GC=F
MARKET_SYMBOL_US500=ES=F

# Verhindert TLS-Fehler via curl_cffi bei Proxy-Umgebungen (IMMER setzen)
YF_DISABLE_CURL_CFFI=1

# Economic Calendar Feed (ForexFactory, kein Auth nötig, max. 2 Requests / 5min pro IP)
ECONOMIC_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
NEWS_FILTER_LOOKAHEAD_HOURS=24
NEWS_FILTER_CURRENCIES=USD,XAU

# GitHub Token für automatischen Push (Classic PAT mit repo-Scope)
# Wird in der Routine als GITHUB_TOKEN gesetzt – niemals in den Code committen
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
